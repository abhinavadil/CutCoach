<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSHealthShareUsageDescription</key>
	<string>Cut Coach reads your steps, sleep, heart rate, and body weight from Apple Health to automatically fill your daily check-in and track your fat-loss progress.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Cut Coach saves your body weight and nutrition data to Apple Health to keep all your health data in sync.</string>
	<key>NSUserNotificationUsageDescription</key>
	<string>Cut Coach sends meal reminders, workout alerts, and coach check-ins to keep you on track with your transformation.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.cutcoach.app.refresh</string>
		<string>com.cutcoach.app.processing</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>CFBundleDisplayName</key>
	<string>Cut Coach</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>x-apple-health</string>
	</array>
</dict>
</plist>
